    "curve": "basis",
    "nodeSpacing": 28,
    "rankSpacing": 34,
    "padding": 8
  },
  "themeVariables": {
    "fontFamily": "Linux Libertine O, Libertine, Georgia, serif",
    "fontSize": "17px",
    "lineColor": "#4b5563",
    "textColor": "#111827",
    "primaryTextColor": "#111827",
    "primaryBorderColor": "#1f77b4",
    "primaryColor": "#e8f1fb",
    "secondaryColor": "#edf7f6",
    "tertiaryColor": "#f6f8fa",
    "background": "transparent",
    "mainBkg": "#f6f8fa",
    "clusterBkg": "#ffffff",
    "edgeLabelBackground": "#ffffff"
  }
